"Europa:Jupiter II" "Sol/Jupiter"
{
	Class	"moon"
	Texture	"europa.*"
	Color	[ 1.0 0.95939 0.85366 ]
	SemiAxes	[ 1562.6 1560.3 1559.5 ]
